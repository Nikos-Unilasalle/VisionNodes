    {
      "id": "note-title",
      "type": "canvas_note",
      "position": { "x": 370, "y": -200 },
      "data": {
        "label": "Note",
        "params": {
          "text": "ÉGALISEUR SPECTRAL FFT — TEMPS RÉEL\n\nContrôle 3 bandes de fréquences spatiales en direct via les sliders.\nLow = structures larges (fond, éclairage) · Mid = formes et textures · High = détails fins et bruit.\n\nLes monitors affichent : spectre original, spectre modifié, résultat reconstruit."
        }
      },
      "width": 640, "height": 150,
      "style": { "width": 640, "height": 150 }
    },
    {
      "id": "note-splits",
      "type": "canvas_note",
      "position": { "x": 700, "y": 490 },
      "data": {
        "label": "Note",
        "params": {
          "text": "Low/Mid split % : fréquence de séparation basses/moyennes (défaut 15%)\nMid/High split % : fréquence de séparation moyennes/hautes (défaut 50%)\n\nExprimés en % du rayon spectral (0=DC, 100=coin de l'image).",
          "color_index": 2
        }
      },
      "width": 270, "height": 110,
      "style": { "width": 270, "height": 110 }
    },
    {
      "id": "note-presets",
      "type": "canvas_note",
      "position": { "x": 40, "y": 490 },
      "data": {
        "label": "Note",
        "params": {
          "text": "PRESETS UTILES\nNetteté : Low=80 Mid=100 High=250\nDébruitage : Low=100 Mid=100 High=20\nFlou artistique : Low=120 Mid=60 High=5\nEmboss fréq. : Low=10 Mid=200 High=80",
          "color_index": 0
        }
      },
      "width": 270, "height": 120,
      "style": { "width": 270, "height": 120 }
    },
