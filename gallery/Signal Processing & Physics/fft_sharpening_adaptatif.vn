    {
      "id": "note-title",
      "type": "canvas_note",
      "position": { "x": 370, "y": -180 },
      "data": {
        "label": "Note",
        "params": {
          "text": "NETTETÉ ADAPTATIVE PAR FFT\n\nBoost des hautes fréquences spatiales dans le domaine de Fourier.\nPlus précis qu'un Unsharp Mask classique : contrôle indépendant par bande.\n\nHigh Freq % > 100 → renforce les contours. Low Freq % < 100 → réduit le voile."
        }
      },
      "width": 620, "height": 145,
      "style": { "width": 620, "height": 145 }
    },
    {
      "id": "note-gain",
      "type": "canvas_note",
      "position": { "x": 700, "y": 490 },
      "data": {
        "label": "Note",
        "params": {
          "text": "Réglages par défaut : netteté douce.\nPour plus d'effet : High Freq % → 350+\nPour effet HDR : Low=60, Mid=120, High=300",
          "color_index": 2
        }
      },
      "width": 270, "height": 90,
      "style": { "width": 270, "height": 90 }
    },
