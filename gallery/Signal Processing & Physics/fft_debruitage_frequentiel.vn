    {
      "id": "note-title",
      "type": "canvas_note",
      "position": { "x": 370, "y": -180 },
      "data": {
        "label": "Note",
        "params": {
          "text": "DÉBRUITAGE FRÉQUENTIEL PAR FFT\n\nAtténuation douce des hautes fréquences spatiales (bruit, grain, artefacts).\nContrairement au flou gaussien, préserve les structures de taille intermédiaire.\n\nHigh Freq % contrôle l'agressivité — Mid/High split détermine la fréquence de coupure."
        }
      },
      "width": 620, "height": 145,
      "style": { "width": 620, "height": 145 }
    },
    {
      "id": "note-gain",
      "type": "canvas_note",
      "position": { "x": 700, "y": 490 },
      "data": {
        "label": "Note",
        "params": {
          "text": "Débruitage léger : High=40%, Mid/High split=55%\nDébruitage fort : High=5%, Mid/High split=40%\nPréserver textures : augmenter Mid/High split",
          "color_index": 2
        }
      },
      "width": 270, "height": 90,
      "style": { "width": 270, "height": 90 }
    },
