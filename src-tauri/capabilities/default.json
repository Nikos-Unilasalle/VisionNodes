{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-rename",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-read-text-file",
    {
      "identifier": "shell:allow-execute",
      "args": [
        {
          "sidecar": true,
          "name": "bin/engine-bin"
        }
      ]
    }
  ]
}
