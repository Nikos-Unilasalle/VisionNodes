{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VisionNodes",
  "version": "0.1.0",
  "identifier": "com.visionnodes.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VisionNodes",
        "width": 1280,
        "height": 800,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [
      "bin/engine-bin"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
  }
}
