    },
    {
      "id": "note-otsu",
      "type": "canvas_note",
      "position": {
        "x": 660,
        "y": 770
      },
      "data": {
        "label": "Note",
        "params": {
          "text": "Otsu calcule automatiquement le seuil optimal en maximisant la variance inter-classes fond/objet.\nOpening élimine le bruit. Closing bouche les petits trous.",
          "color_index": 0
        }
      },
      "width": 270,
      "height": 95,
      "style": {
        "width": 270,
        "height": 95
      },
      "selected": false
    },
    {
      "id": "note-dist",
      "type": "canvas_note",
      "position": {
        "x": 960,
        "y": 870
      },
      "data": {
        "label": "Note",
        "params": {
          "text": "La transformée en distance : chaque pixel blanc prend pour valeur sa distance au bord le plus proche. Les maxima locaux correspondent aux centres des particules → graines du Watershed.",
          "color_index": 0
        }
      },
      "width": 560,
      "height": 95,
      "style": {
        "width": 560,
        "height": 95
      },
      "selected": false
    },
    {
      "id": "note-watershed",
      "type": "canvas_note",
      "position": {
        "x": 1571.0082651772213,
        "y": 412.26145657651637
      },
      "data": {
        "label": "Note",
        "params": {
          "text": "Watershed simule une inondation depuis les graines. Il sépare les particules qui se touchent là où les bassins versants se rencontrent (frontières blanches).",
          "color_index": 0
        }
      },
      "width": 260,
