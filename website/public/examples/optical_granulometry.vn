    {
      "id": "note-title",
      "type": "canvas_note",
      "position": {
        "x": 960,
        "y": -160
      },
      "data": {
        "label": "Note",
        "params": {
          "text": "GRANULOMÉTRIE OPTIQUE\n\nPipeline complet d'analyse quantitative de particules par segmentation Watershed.\nMesure automatique : nombre, aire moyenne, distribution de taille.\n\nApplications : sciences des matériaux, géologie, microscopie, contrôle qualité."
        }
      },
      "width": 560,
      "height": 170,
      "style": {
        "width": 560,
        "height": 170
      },
      "selected": true,
      "positionAbsolute": {
        "x": 960,
        "y": -160
      },
      "dragging": false,
      "resizing": false
    },
    {
      "id": "note-import",
      "type": "canvas_note",
      "position": {
        "x": 104.97609120179513,
        "y": 828.3185924999605
      },
      "data": {
        "label": "Note",
        "params": {
          "text": "Remplacez billes.jpg par votre propre image : grains de sable, cellules, bulles, pores, galets…\n\nUtilisez le node Input Image pour importer via Cmd+O ou glisser-déposer.",
          "color_index": 0
        }
      },
      "width": 220,
      "height": 110,
      "style": {
        "width": 220,
        "height": 110
      },
      "selected": false,
